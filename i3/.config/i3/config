# Gaps
gaps inner 4
gaps outer 8

# Terminal
set $term ghostty

# Keybindings
bindsym $mod+d exec rofi -show drun -show-icons
bindsym $mod+Shift+e kill

## Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

## Move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

## Resize
bindsym $mod+Ctrl+h resize shrink width 10 px
bindsym $mod+Ctrl+l resize grow width 10 px
bindsym $mod+Ctrl+k resize grow height 10 px
bindsym $mod+Ctrl+j resize shrink height 10 px

## Workspaces
bindsym $mod+2 workspace 2
bindsym $mod+1 workspace 1
bindsym $mod+0 workspace 0

bindsym $mod+Shift+b move container to workspace 2
bindsym $mod+Shift+1 move container to workspace 1

# Move Ghostty to workspace 1
for_window [class="ghostty"] move to workspace 1
for_window [class="firefox"] move to workspace 2

# Borders
default_border pixel 1

# Window rules
for_window [class="ghostty"] border none
for_window [class="firefox"] border none

# Font
font pango:JetBrainsMono Nerd Font 19

# Start workspace
exec --no-startup-id i3-msg workspace 1

# Autostart
exec --no-startup-id ghostty
